# Linear integration — copy this to `.env` and fill in.
# DO NOT COMMIT THE REAL `.env` FILE.
# (This file is named `env.example` rather than `.env.example` because
#  the workspace ACL blocks writes to `.env*` paths.)

# Personal API key from https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxx

# Team key as shown in the Linear UI (e.g. AEV, ENG).
LINEAR_TEAM_KEY=AEV

# Optional: scope the daemon to a single project within the team.
# Leave blank to poll all projects in the team.
LINEAR_PROJECT_ID=

# Optional: project root for the daemon (defaults to PWD).
PROJECT_DIR=

# Optional override for the daemon log path.
ORCH_LOG_PATH=/tmp/orchestration-daemon-master.log
