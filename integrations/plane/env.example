# Plane integration — copy this to `.env` and fill in.
# DO NOT COMMIT THE REAL `.env` FILE.
# (Named `env.example` rather than `.env.example` because the workspace
#  ACL blocks writes to `.env*` paths. Symlink or rename when adopting.)

# API token: workspace Settings → API tokens
PLANE_API_KEY=plane_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# Workspace slug (from your URL: https://app.plane.so/<slug>/...)
PLANE_WORKSPACE_SLUG=my-workspace

# Project UUID (from the project URL)
PLANE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# API base URL. Default is the hosted Plane endpoint; override for
# self-hosted (e.g. https://plane.example.com/api/v1).
PLANE_API_BASE_URL=https://api.plane.so/api/v1

# Optional: project root for the daemon (defaults to PWD).
PROJECT_DIR=

# Optional override for the daemon log path.
ORCH_LOG_PATH=/tmp/orchestration-daemon-master.log
